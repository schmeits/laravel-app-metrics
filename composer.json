{
    "name": "schmeits/laravel-app-metrics",
    "description": "Push business metrics from Laravel apps to a central dashboard",
    "keywords": ["laravel", "metrics", "dashboard", "kpi"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "laravel/pint": "^1.14"
    },
    "autoload": {
        "psr-4": {
            "Schmeits\\AppMetrics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Schmeits\\AppMetrics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Schmeits\\AppMetrics\\AppMetricsServiceProvider"
            ],
            "aliases": {
                "AppMetrics": "Schmeits\\AppMetrics\\Facades\\AppMetrics"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
